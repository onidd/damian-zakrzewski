---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Damian Zakrzewski">
	<main class="mt-4 max-w-2xl">
		
		<h1 class="font-['Cormorant_Garamond'] italic text-4xl sm:text-5xl text-slate-900 mb-10 tracking-wide leading-tight">
			Get in Touch
		</h1>
		
		<div class="text-slate-600 leading-relaxed text-sm sm:text-base space-y-10">
			
			<p>
				I am always open to discussing research collaborations, bioinformatics projects, or new academic opportunities. 
				Feel free to reach out using the addresses below.
			</p>

			<!-- Sekcja z mailami -->
			<div class="space-y-6">
				
				<!-- Mail uczelniany -->
				<div>
					<h2 class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mb-1.5">
						Academic Inquiries
					</h2>
					<a href="mailto:damian.zakrzewski@student.put.poznan.pl" class="text-lg sm:text-xl font-['Cormorant_Garamond'] italic text-slate-900 underline decoration-slate-200 underline-offset-4 hover:decoration-slate-900 transition-colors">
						damian.zakrzewski@student.put.poznan.pl
					</a>
				</div>

				<!-- Mail prywatny -->
				<div>
					<h2 class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mb-1.5">
						General Contact
					</h2>
					<a href="mailto:damianzakrzewski264@gmail.com" class="text-lg sm:text-xl font-['Cormorant_Garamond'] italic text-slate-900 underline decoration-slate-200 underline-offset-4 hover:decoration-slate-900 transition-colors">
						damianzakrzewski264@gmail.com
					</a>
				</div>

			</div>

			<!-- Elegancka stopka lokalizacyjna (bez podawania prywatnego adresu) -->
			<div class="pt-8 border-t border-slate-900/5">
				<h2 class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mb-2">
					Current Affiliation
				</h2>
				<p class="text-slate-900 font-medium">Poznań University of Technology</p>
				<p class="text-slate-500 text-sm">Poznań, Poland</p>
			</div>

		</div>
	</main>
</Layout>
